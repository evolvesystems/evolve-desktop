{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "identifier": "default",
  "description": "Default capabilities for EvolveApp dual-webview architecture",
  "windows": ["main"],
  "webviews": ["sidebar", "content", "main", "tabbar", "tab_1", "tab_2", "tab_3", "tab_4", "tab_5", "tab_6", "tab_7", "tab_8", "tab_9", "tab_10", "tab_11", "tab_12", "tab_13", "tab_14", "tab_15", "tab_16", "tab_17", "tab_18", "tab_19", "tab_20"],
  "permissions": [
    "core:default",
    "core:window:allow-center",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:window:allow-inner-size",
    "core:webview:allow-create-webview",
    "core:webview:allow-set-webview-size",
    "core:webview:allow-set-webview-position",
    "core:webview:allow-webview-close",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-listen",
    "core:app:allow-app-show",
    "core:app:allow-app-hide",
    "core:app:allow-version",
    "shell:allow-open",
    "http:default",
    "notification:default"
  ]
}
