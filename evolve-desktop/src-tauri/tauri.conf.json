{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "EvolveApp",
  "version": "2.4.2",
  "identifier": "com.evolveapp.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "https://evolvepreneuriq.app",
    "beforeBuildCommand": "node build-frontend.js",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    },
    "resources": [
      "assets/*"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "frameworks": [],
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    }
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "evolveapp",
          "mailto"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://evolvepreneuriq.app/api/v1/desktop/updates/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzQzZBRjIyQ0IzOUMyMjMKUldRandqbkxJcS9HOHlTT2ZCcUE3YUptVGtLM004Y0RmRzhRSVZEVjAzc01ndGVDV1lWVVlqZkoK"
    }
  }
}
